DB_URL=jdbc:postgresql://localhost:5432/vote_system
DB_USERNAME=vote
DB_PASSWORD=vote
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT=2s
REDIS_COMMAND_TIMEOUT=2s
REDIS_HEALTH_ENABLED=true
CACHE_DEFAULT_TTL=PT30S
JWT_SECRET=replace-this-with-at-least-32-random-characters
JWT_ISSUER=vote-system
ACCESS_TOKEN_TTL=PT15M
REFRESH_TOKEN_TTL=P30D
REFRESH_COOKIE_NAME=vote_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=Lax
